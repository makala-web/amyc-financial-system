'use client';

import { useEffect, useState } from 'react';
import { useForm } from 'react-hook-form';
import { z } from 'zod';
import { zodResolver } from '@hookform/resolvers/zod';
import { db, getCategories } from '@/lib/db-offline';
import { addTransaction } from '@/lib/storage/transaction-store';
import {
  notifyTransactionsChanged,
  queueTransactionCreate,
  transactionSaveToast,
} from '@/lib/transaction-sync';
import { useAuthStore, useFinancialStore } from '@/lib/store';
import { ALLOW_CUSTOM_EXPENSE_CATEGORY, DEPARTMENTS, MONTHS } from '@/lib/types';
import type { Category, Department, OrgLevel } from '@/lib/types';

import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Textarea } from '@/components/ui/textarea';
import { Calendar } from '@/components/ui/calendar';
import { Popover, PopoverContent, PopoverTrigger } from '@/components/ui/popover';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import {
  Form, FormControl, FormField, FormItem, FormLabel, FormMessage,
} from '@/components/ui/form';
import { toast } from 'sonner';
import { CalendarIcon, MinusCircle, PlusCircle } from 'lucide-react';
import { format } from 'date-fns';

// Zod schema
const expenseSchema = z.object({
  date: z.date(),
  categoryId: z.string().min(1, 'Chagua aina ya matumizi'),
  department: z.string().min(1, 'Chagua idara'),
  item: z.string().min(1, 'Taja bidhaa/huduma'),
  unit: z.string().optional(),
  quantity: z.coerce.number().min(1, 'Idadi lazima iwe zaidi ya 0'),
  unitPrice: z.coerce.number().min(1, 'Bei lazima iwe zaidi ya 0'),
  vendor: z.string().optional(),
  description: z.string().optional(),
});

type ExpenseFormValues = z.infer<typeof expenseSchema>;

export default function ExpenseForm() {
  const { currentOrg, currentUser } = useAuthStore();
  const { setSelectedYear, setSelectedMonth } = useFinancialStore();
  const [categories, setCategories] = useState<Category[]>([]);
  const [showAddCategory, setShowAddCategory] = useState(false);
  const [newCategoryName, setNewCategoryName] = useState('');
  const [submitting, setSubmitting] = useState(false);
  const [calendarOpen, setCalendarOpen] = useState(false);

  const form = useForm<ExpenseFormValues>({
    resolver: zodResolver(expenseSchema) as any,
    defaultValues: {
      date: new Date(),
      categoryId: '',
      department: '',
      item: '',
      unit: '',
      quantity: 1,
      unitPrice: 0,
      vendor: '',
      description: '',
    },
  });

  // Load expense categories
  useEffect(() => {
    async function loadCategories() {
      const cats = await getCategories('expense');
      setCategories(cats);
    }
    loadCategories();
  }, []);

  // Auto-fill month/year when date changes
  const watchedDate = form.watch('date');
  useEffect(() => {
    if (watchedDate) {
      setSelectedMonth(watchedDate.getMonth() + 1);
      setSelectedYear(watchedDate.getFullYear());
    }
  }, [watchedDate, setSelectedMonth, setSelectedYear]);

  // Auto-calculate total
  const quantity = form.watch('quantity') || 0;
  const unitPrice = form.watch('unitPrice') || 0;
  const total = quantity * unitPrice;

  // Add new category
  const handleAddCategory = async () => {
    if (!newCategoryName.trim()) return;
    const orgLevel = currentOrg?.type || 'tawi';
    await db.categories.add({
      name: newCategoryName.trim(),
      type: 'expense',
      isActive: true,
      isDefault: false,
      orgLevel: orgLevel as OrgLevel,
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString(),
    });
    const cats = await getCategories('expense');
    setCategories(cats);
    setNewCategoryName('');
    setShowAddCategory(false);
    toast.success('Kundi jipya limeongezwa!');
  };

  // Submit form
  const onSubmit = async (data: ExpenseFormValues) => {
    if (!currentOrg || !currentUser) {
      toast.error('Tafadhali ingia kwanza');
      return;
    }
    setSubmitting(true);
    try {
      const selectedCategory = categories.find(c => c.id === Number(data.categoryId));
      const month = data.date.getMonth() + 1;
      const year = data.date.getFullYear();

      const localId = (await addTransaction({
        type: 'expense',
        amount: total,
        date: data.date.toISOString(),
        month,
        year,
        department: data.department as Department,
        categoryId: Number(data.categoryId),
        category_name: selectedCategory?.name || '',
        description: data.description || '',
        item: data.item || '',
        vendor: data.vendor || '',
        quantity: data.quantity,
        unitPrice: data.unitPrice,
        unit: data.unit || '',
        orgUnitId: currentOrg.id!,
        orgUnitName: currentOrg.name,
        orgLevel: currentOrg.type,
        enteredBy: currentUser.id!,
        createdAt: new Date().toISOString(),
        updatedAt: new Date().toISOString(),
      })) as number;

      const saved = await db.transactions.get(localId);
      if (saved?.id) {
        queueTransactionCreate(saved as typeof saved & { id: number });
      }
      notifyTransactionsChanged({
        orgUnitId: currentOrg.id!,
        orgLevel: currentOrg.type,
        type: 'expense',
        year,
        month,
      });

      toast.success(`Matumizi yameingizwa kikamilifu! ${transactionSaveToast(navigator.onLine)}`);
      form.reset({
        date: new Date(),
        categoryId: '',
        department: '',
        item: '',
        unit: '',
        quantity: 1,
        unitPrice: 0,
        vendor: '',
        description: '',
      });
    } catch (err) {
      console.error('Error saving expense:', err);
      toast.error('Kuna hitilafu. Jaribu tena.');
    } finally {
      setSubmitting(false);
    }
  };

  const formatCurrency = (val: number) =>
    new Intl.NumberFormat('sw-TZ', { style: 'decimal', minimumFractionDigits: 0 }).format(val);

  return (
    <Card className="w-full max-w-2xl mx-auto">
      <CardHeader className="p-4 sm:p-6">
        <CardTitle className="text-lg sm:text-xl text-orange-700 flex items-center gap-2">
          <MinusCircle className="size-5" />
          Ingiza Matumizi
        </CardTitle>
      </CardHeader>
      <CardContent className="p-4 pt-0 sm:p-6 sm:pt-0">
        <Form {...form}>
          <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-4 sm:space-y-5">
            {/* Date Picker */}
            <FormField
              control={form.control}
              name="date"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Tarehe</FormLabel>
                  <Popover open={calendarOpen} onOpenChange={setCalendarOpen}>
                    <PopoverTrigger asChild>
                      <FormControl>
                        <Button
                          variant="outline"
                          className="w-full justify-start text-left font-normal border-orange-200 min-h-[44px]"
                        >
                          <CalendarIcon className="size-4 mr-2 text-orange-600" />
                          {field.value ? format(field.value, 'dd/MM/yyyy') : 'Chagua tarehe'}
                        </Button>
                      </FormControl>
                    </PopoverTrigger>
                    <PopoverContent className="w-auto p-0" align="start">
                      <Calendar
                        mode="single"
                        selected={field.value}
                        onSelect={(date) => {
                          field.onChange(date);
                          setCalendarOpen(false);
                        }}
                        initialFocus
                      />
                    </PopoverContent>
                  </Popover>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Auto-filled Month/Year display */}
            <div className="grid grid-cols-2 gap-3">
              <div>
                <p className="text-sm font-medium text-muted-foreground mb-1">Mwezi</p>
                <p className="text-sm font-medium px-3 py-2 bg-muted rounded-md border">
                  {watchedDate ? MONTHS[watchedDate.getMonth()] : '-'}
                </p>
              </div>
              <div>
                <p className="text-sm font-medium text-muted-foreground mb-1">Mwaka</p>
                <p className="text-sm font-medium px-3 py-2 bg-muted rounded-md border">
                  {watchedDate ? watchedDate.getFullYear() : '-'}
                </p>
              </div>
            </div>

            {/* Expense Category */}
            <FormField
              control={form.control}
              name="categoryId"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Aina ya Matumizi</FormLabel>
                  <div className="flex gap-2">
                    <Select onValueChange={field.onChange} value={field.value}>
                      <FormControl>
                        <SelectTrigger className="flex-1 border-orange-200 min-h-[44px]">
                          <SelectValue placeholder="Chagua aina" />
                        </SelectTrigger>
                      </FormControl>
                      <SelectContent>
                        {categories.map(cat => (
                          <SelectItem key={cat.id} value={String(cat.id)}>
                            {cat.name}
                          </SelectItem>
                        ))}
                      </SelectContent>
                    </Select>
                    {ALLOW_CUSTOM_EXPENSE_CATEGORY && (
                      <Button
                        type="button"
                        variant="outline"
                        size="icon"
                        className="shrink-0 border-orange-300 text-orange-600 hover:bg-orange-50 h-11 w-11"
                        onClick={() => setShowAddCategory(!showAddCategory)}
                      >
                        <PlusCircle className="size-4" />
                      </Button>
                    )}
                  </div>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Add Category Panel */}
            {ALLOW_CUSTOM_EXPENSE_CATEGORY && showAddCategory && (
              <div className="flex gap-2 items-end border border-dashed border-orange-300 rounded-lg p-3 bg-orange-50/50">
                <div className="flex-1">
                  <label className="text-xs font-medium text-orange-700 mb-1 block">Kundi Jipya</label>
                  <Input
                    value={newCategoryName}
                    onChange={(e) => setNewCategoryName(e.target.value)}
                    placeholder="Jina la kundi jipya..."
                    className="border-orange-200"
                  />
                </div>
                <Button
                  type="button"
                  size="sm"
                  className="bg-orange-600 hover:bg-orange-700 text-white"
                  onClick={handleAddCategory}
                >
                  Ongeza
                </Button>
              </div>
            )}

            {/* Department */}
            <FormField
              control={form.control}
              name="department"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Idara</FormLabel>
                  <Select onValueChange={field.onChange} value={field.value}>
                    <FormControl>
                      <SelectTrigger className="border-orange-200 min-h-[44px]">
                        <SelectValue placeholder="Chagua idara" />
                      </SelectTrigger>
                    </FormControl>
                    <SelectContent>
                      {DEPARTMENTS.map(dept => (
                        <SelectItem key={dept} value={dept}>
                          {dept}
                        </SelectItem>
                      ))}
                    </SelectContent>
                  </Select>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Item / Service */}
            <FormField
              control={form.control}
              name="item"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Bidhaa/Huduma</FormLabel>
                  <FormControl>
                    <Input
                      placeholder="Jina la bidhaa au huduma..."
                      className="border-orange-200 min-h-[44px]"
                      {...field}
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Unit, Quantity, Unit Price */}
            <div className="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <FormField
                control={form.control}
                name="unit"
                render={({ field }) => (
                  <FormItem>
                    <FormLabel>Kipimo</FormLabel>
                    <FormControl>
                      <Input
                        placeholder="pcs, kg..."
                        className="border-orange-200 min-h-[44px]"
                        {...field}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
              <FormField
                control={form.control}
                name="quantity"
                render={({ field }) => (
                  <FormItem>
                    <FormLabel>Idadi</FormLabel>
                    <FormControl>
                      <Input
                        type="number"
                        min={1}
                        className="border-orange-200 min-h-[44px]"
                        {...field}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
              <FormField
                control={form.control}
                name="unitPrice"
                render={({ field }) => (
                  <FormItem>
                    <FormLabel>Bei (TSh)</FormLabel>
                    <FormControl>
                      <Input
                        type="number"
                        min={1}
                        className="border-orange-200 min-h-[44px]"
                        {...field}
                      />
                    </FormControl>
                    <FormMessage />
                  </FormItem>
                )}
              />
            </div>

            {/* Total (auto-calculated) */}
            <div className="bg-orange-50 border border-orange-200 rounded-lg p-3">
              <div className="flex justify-between items-center">
                <span className="text-sm font-medium text-orange-700">Jumla (Idadi × Bei)</span>
                <span className="text-lg font-bold text-orange-600">{formatCurrency(total)} TSh</span>
              </div>
            </div>

            {/* Vendor */}
            <FormField
              control={form.control}
              name="vendor"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Muuzaji</FormLabel>
                  <FormControl>
                    <Input
                      placeholder="Jina la muuzaji..."
                      className="border-orange-200 min-h-[44px]"
                      {...field}
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Description */}
            <FormField
              control={form.control}
              name="description"
              render={({ field }) => (
                <FormItem>
                  <FormLabel>Maelezo</FormLabel>
                  <FormControl>
                    <Textarea
                      placeholder="Maelezo ya matumizi..."
                      className="border-orange-200 min-h-[80px]"
                      {...field}
                    />
                  </FormControl>
                  <FormMessage />
                </FormItem>
              )}
            />

            {/* Submit */}
            <Button
              type="submit"
              className="w-full bg-orange-600 hover:bg-orange-700 text-white min-h-[44px]"
              disabled={submitting}
            >
              {submitting ? 'Inahifadhi...' : 'Hifadhi Matumizi'}
            </Button>
          </form>
        </Form>
      </CardContent>
    </Card>
  );
}
